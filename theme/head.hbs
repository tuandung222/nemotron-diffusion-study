<script type="text/x-mathjax-config">
  // mdBook ships MathJax v2.7.1 with the TeX-AMS-MML_HTMLorMML config preset.
  // Enable single-dollar `$...$` inline math (default MathJax 2 only matches
  // `\(...\)` and `\[...\]`). Keep `$$...$$` for display math.
  MathJax.Hub.Config({
    tex2jax: {
      inlineMath: [['$', '$'], ['\\(', '\\)']],
      displayMath: [['$$', '$$'], ['\\[', '\\]']],
      processEscapes: true,
      processEnvironments: true,
      skipTags: ['script', 'noscript', 'style', 'textarea', 'pre', 'code']
    },
    TeX: {
      equationNumbers: { autoNumber: 'none' },
      extensions: ['AMSmath.js', 'AMSsymbols.js']
    }
  });
</script>
